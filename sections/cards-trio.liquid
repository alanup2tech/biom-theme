{{ 'section-content-bands.css' | asset_url | stylesheet_tag }}

<section class="cards-trio cards-trio--{{ section.settings.background }}{% if section.settings.background == 'olive' %} noise{% endif %}">
  <div class="page-width">
    <div class="cards-trio__intro reveal">
      <h2 class="cards-trio__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="cards-trio__text">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="cards-trio__grid">
      {%- for block in section.blocks -%}
        <div class="trio-card reveal" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="trio-card__media">
              <img width="1100" height="825" src="{{ block.settings.image | image_url: width: 1100 }}" alt="" loading="lazy">
            </div>
          {%- elsif block.settings.icon_asset != blank -%}
            <div class="trio-card__icon">
              <img width="600" height="450" src="{{ block.settings.icon_asset | asset_url }}" alt="" loading="lazy">
            </div>
          {%- endif -%}
          <h3 class="trio-card__title">{{ block.settings.title }}</h3>
          <p class="trio-card__text">{{ block.settings.text }}</p>
          {%- if block.settings.tag != blank -%}
            <span class="trio-card__tag">{{ block.settings.tag }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="cards-trio__cta">
        <a class="btn" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cards trio",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built on a Foundation Most Probiotics Ignore" },
    { "type": "textarea", "id": "text", "label": "Text" },
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "cream", "label": "Cream" },
        { "value": "cream-bright", "label": "Bright cream" },
        { "value": "olive", "label": "Olive" }
      ],
      "default": "white"
    },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "icon_asset", "label": "Icon asset filename" },
        { "type": "text", "id": "title", "label": "Title", "default": "Biomsify® Fermentation" },
        { "type": "textarea", "id": "text", "label": "Text" },
        { "type": "text", "id": "tag", "label": "Tag" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Cards trio",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}
