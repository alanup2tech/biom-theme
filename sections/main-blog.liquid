{{ 'component-aux.css' | asset_url | stylesheet_tag }}

<section class="aux-page">
  <div class="page-width">
    <h1 class="aux-page__heading" style="text-align:center;">{{ blog.title }}</h1>

    {%- paginate blog.articles by 9 -%}
      <div class="blog-grid">
        {%- for article in blog.articles -%}
          <a class="article-card" href="{{ article.url }}">
            {%- if article.image -%}
              <img width="800" height="600" class="article-card__image" src="{{ article.image | image_url: width: 800 }}" alt="{{ article.image.alt | escape }}" loading="lazy">
            {%- endif -%}
            <span class="article-card__body">
              <span class="article-card__title">{{ article.title }}</span>
              <span class="article-card__meta">{{ article.published_at | date: '%B %d, %Y' }}</span>
            </span>
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">&larr;</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="pagination__current">{{ part.title }}</span>
            {%- else -%}
              <span>{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">&rarr;</a>{%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
