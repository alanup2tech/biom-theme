{{ 'component-aux.css' | asset_url | stylesheet_tag }}

<section class="aux-page aux-page--center">
  <div class="page-width">
    <h1 class="aux-page__heading">Activate account</h1>
    <p class="aux-page__sub">Create your password to activate your account.</p>

    {%- form 'activate_customer_password', class: 'customer-form' -%}
      {{ form.errors | default_errors }}
      <div>
        <label for="ActivatePassword">{{ 'customer.login.password' | t }}</label>
        <input type="password" name="customer[password]" id="ActivatePassword" required>
      </div>
      <div>
        <label for="ActivatePasswordConfirm">Confirm password</label>
        <input type="password" name="customer[password_confirmation]" id="ActivatePasswordConfirm" required>
      </div>
      <button class="btn" type="submit">Activate account</button>
      <button class="btn btn--dark" type="submit" name="decline">Decline invitation</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Activate account",
  "settings": []
}
{% endschema %}
