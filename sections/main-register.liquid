{{ 'component-aux.css' | asset_url | stylesheet_tag }}

<section class="aux-page aux-page--center">
  <div class="page-width">
    <h1 class="aux-page__heading">{{ 'customer.login.create_account' | t }}</h1>

    {%- form 'create_customer', class: 'customer-form' -%}
      {{ form.errors | default_errors }}
      <div>
        <label for="RegisterFirstName">First name</label>
        <input type="text" name="customer[first_name]" id="RegisterFirstName" autocomplete="given-name">
      </div>
      <div>
        <label for="RegisterLastName">Last name</label>
        <input type="text" name="customer[last_name]" id="RegisterLastName" autocomplete="family-name">
      </div>
      <div>
        <label for="RegisterEmail">{{ 'customer.login.email' | t }}</label>
        <input type="email" name="customer[email]" id="RegisterEmail" autocomplete="email" required>
      </div>
      <div>
        <label for="RegisterPassword">{{ 'customer.login.password' | t }}</label>
        <input type="password" name="customer[password]" id="RegisterPassword" required>
      </div>
      <button class="btn" type="submit">{{ 'customer.login.create_account' | t }}</button>
      <div class="customer-links">
        <a href="{{ routes.account_login_url }}">{{ 'customer.login.sign_in' | t }}</a>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Register",
  "settings": []
}
{% endschema %}
