{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-products.css' | asset_url | stylesheet_tag }}

<section class="featured-products noise">
  <div class="page-width">
    <h2 class="featured-products__heading reveal">{{ section.settings.heading }}</h2>

    <div class="featured-products__grid" data-carousel>
      {%- liquid
        assign badge = section.settings.badge_text
        assign rendered = 0
      -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.product != blank -%}
          {%- assign rendered = rendered | plus: 1 -%}
          {% render 'card-product', product: block.settings.product, badge: badge %}
        {%- endif -%}
      {%- endfor -%}

      {%- if rendered == 0 and section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: 4 -%}
          {%- assign rendered = rendered | plus: 1 -%}
          {% render 'card-product', product: product, badge: badge %}
        {%- endfor -%}
      {%- endif -%}

      {%- if rendered == 0 -%}
        {%- comment -%} Design fallback — Figma static content {%- endcomment -%}
        {% render 'card-product', title: 'Biom Probiotics', image_asset: 'product-biom.png', price: '$19.95', badge: badge %}
        {% render 'card-product', title: 'LeanBiom', image_asset: 'product-leanbiom.png', price: '$19.95', badge: badge %}
        {% render 'card-product', title: 'Longiva', image_asset: 'product-longiva.png', price: '$19.95', badge: badge %}
        {% render 'card-product', title: "VFlora Women's Daily", image_asset: 'product-vflora.png', price: '$19.95', badge: badge %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Most Popular Microbiome Systems"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Subscribe & Save 15%"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used when no product blocks are added (first 4 products)"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [{ "type": "product", "id": "product", "label": "Product" }]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
