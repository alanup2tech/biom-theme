{{ 'component-aux.css' | asset_url | stylesheet_tag }}

<section class="aux-page aux-page--center" style="background: var(--color-cream); min-height: 70vh; display: flex; align-items: center;">
  <div class="page-width" style="width: 100%;">
    {{ 'logo-biom.svg' | inline_asset_content }}
    <h1 class="aux-page__heading" style="margin-top: 2rem;">{{ shop.name }}</h1>
    <p class="aux-page__sub">Opening soon — sign up to be the first to know.</p>

    {%- form 'customer', class: 'customer-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div>
        <label for="PasswordEmail" class="visually-hidden">{{ 'newsletter.label' | t }}</label>
        <input type="email" name="contact[email]" id="PasswordEmail" placeholder="{{ 'newsletter.label' | t }}" required>
      </div>
      <button class="btn" type="submit">{{ 'newsletter.button_label' | t }}</button>
    {%- endform -%}

    {%- if shop.password_message != blank -%}
      <p class="aux-page__sub" style="margin-top: 2rem;">{{ shop.password_message }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}
