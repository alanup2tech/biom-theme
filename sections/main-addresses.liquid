{{ 'component-aux.css' | asset_url | stylesheet_tag }}

<section class="aux-page">
  <div class="page-width">
    <h1 class="aux-page__heading">Addresses</h1>
    <div class="customer-links" style="justify-content: flex-start;">
      <a href="{{ routes.account_url }}">{{ 'customer.account.title' | t }}</a>
    </div>

    <div style="max-width: 480px; margin-top: 2rem;">
      <h2 class="aux-page__sub">Add a new address</h2>
      {%- form 'customer_address', customer.new_address, class: 'customer-form' -%}
        <div><label>First name</label><input type="text" name="address[first_name]" autocomplete="given-name"></div>
        <div><label>Last name</label><input type="text" name="address[last_name]" autocomplete="family-name"></div>
        <div><label>Address</label><input type="text" name="address[address1]" autocomplete="address-line1"></div>
        <div><label>Apartment, suite, etc.</label><input type="text" name="address[address2]" autocomplete="address-line2"></div>
        <div><label>City</label><input type="text" name="address[city]" autocomplete="address-level2"></div>
        <div>
          <label>Country/region</label>
          <select name="address[country]" data-default="{{ customer.new_address.country }}">{{ all_country_option_tags }}</select>
        </div>
        <div><label>Postal/ZIP code</label><input type="text" name="address[zip]" autocomplete="postal-code"></div>
        <div><label>Phone</label><input type="tel" name="address[phone]" autocomplete="tel"></div>
        <button class="btn" type="submit">Add address</button>
      {%- endform -%}
    </div>

    <h2 class="aux-page__sub" style="margin-top: 3rem;">Saved addresses</h2>
    {%- paginate customer.addresses by 6 -%}
      {%- for address in customer.addresses -%}
        <div style="padding: 1.25rem 0; border-bottom: 1px solid rgba(51,51,51,0.1);">
          {%- if address == customer.default_address -%}<strong>Default</strong><br>{%- endif -%}
          {{ address | format_address }}
          {%- form 'customer_address', address -%}
            <button class="cart-line__remove" type="submit" name="_method" value="delete">Delete</button>
          {%- endform -%}
        </div>
      {%- endfor -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Addresses",
  "settings": []
}
{% endschema %}
