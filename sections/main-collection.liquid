{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
{{ 'section-main-collection.css' | asset_url | stylesheet_tag }}

<section class="main-collection" data-section-id="{{ section.id }}">
  {%- if section.settings.show_tabs -%}
    <nav class="collection-tabs" aria-label="Collections" data-collection-tabs>
      {%- for block in section.blocks -%}
        {%- if block.type == 'tab' -%}
          {%- assign tab_collection = collections[block.settings.collection] -%}
          {%- assign is_active = false -%}
          {%- if tab_collection.handle == collection.handle -%}
            {%- assign is_active = true -%}
          {%- endif -%}
          <button
            type="button"
            class="collection-tabs__tab{% if is_active %} is-active{% endif %}"
            data-collection-handle="{{ tab_collection.handle }}"
            data-collection-heading="{{ block.settings.heading | escape }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.heading }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  {%- endif -%}

  <div class="page-width">
    {%- if section.settings.subheading != blank -%}
      <p class="main-collection__subheading reveal" data-collection-subheading>{{ section.settings.subheading }}</p>
    {%- endif -%}
    <h2 class="main-collection__heading reveal" data-collection-title>
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- else -%}
        {{ collection.title }}
      {%- endif -%}
    </h2>

    <div data-collection-content>
      {%- paginate collection.products by section.settings.products_per_page -%}
        {%- if collection.products.size > 0 -%}
          <div class="main-collection__grid">
            {%- liquid
              assign promo_pos = section.settings.promo_position
              assign idx = 0
            -%}
            {%- for product in collection.products -%}
              {%- assign idx = idx | plus: 1 -%}
              {%- if section.settings.promo_image != blank and idx == promo_pos and paginate.current_page == 1 -%}
                <div class="main-collection__promo">
                  <img width="1200" height="900" src="{{ section.settings.promo_image | image_url: width: 1720 }}" alt="" loading="lazy">
                  {%- if section.settings.promo_text != blank -%}
                    <div class="main-collection__promo-text">{{ section.settings.promo_text }}</div>
                  {%- endif -%}
                </div>
              {%- endif -%}
              {% render 'card-product', product: product, badge: section.settings.badge_text %}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.page' | t: number: '' }}">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">&larr;</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="pagination__current" aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span>{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">&rarr;</a>
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- else -%}
          <div class="main-collection__empty">
            <p class="h3">{{ 'templates.collection.empty' | t }}</p>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </div>
</section>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var section = document.querySelector('[data-section-id="' + sectionId + '"]');
  if (!section) return;

  var tabsContainer = section.querySelector('[data-collection-tabs]');
  var titleEl = section.querySelector('[data-collection-title]');
  var subheadingEl = section.querySelector('[data-collection-subheading]');
  var contentEl = section.querySelector('[data-collection-content]');
  if (!tabsContainer || !titleEl || !contentEl) return;

  var tabs = tabsContainer.querySelectorAll('.collection-tabs__tab');
  var currentHandle = '{{ collection.handle }}';
  var isLoading = false;

  function setActiveTab(handle) {
    tabs.forEach(function(tab) {
      tab.classList.toggle('is-active', tab.dataset.collectionHandle === handle);
    });
  }

  function loadCollection(handle, heading) {
    if (isLoading || handle === currentHandle) return;
    isLoading = true;

    contentEl.classList.add('is-loading');
    setActiveTab(handle);

    var url = '/collections/' + handle + '?sections=main-collection';

    fetch(url)
      .then(function(response) {
        if (!response.ok) throw new Error('Network response was not ok');
        return response.text();
      })
      .then(function(html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newContent = doc.querySelector('[data-collection-content]');
        var newTitle = doc.querySelector('[data-collection-title]');

        if (newContent) {
          contentEl.innerHTML = newContent.innerHTML;
        }
        if (heading) {
          titleEl.textContent = heading;
        } else if (newTitle) {
          titleEl.textContent = newTitle.textContent;
        }

        currentHandle = handle;
        window.history.pushState({ handle: handle }, '', '/collections/' + handle);

        contentEl.classList.remove('is-loading');
        isLoading = false;

        initReveals(contentEl);
      })
      .catch(function() {
        window.location.href = '/collections/' + handle;
      });
  }

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var handle = this.dataset.collectionHandle;
      var heading = this.dataset.collectionHeading;
      loadCollection(handle, heading);
    });
  });

  window.addEventListener('popstate', function(e) {
    if (e.state && e.state.handle) {
      loadCollection(e.state.handle, null);
    }
  });

  function initReveals(scope) {
    var items = (scope || document).querySelectorAll('.reveal:not(.is-visible)');
    if (!('IntersectionObserver' in window)) {
      items.forEach(function(el) { el.classList.add('is-visible'); });
      return;
    }
    var io = new IntersectionObserver(
      function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
    );
    items.forEach(function(el) { io.observe(el); });
  }
})();
</script>

{% schema %}
{
  "name": "Collection grid",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "show_tabs", "label": "Show collection tabs", "default": true },
    { "type": "text", "id": "heading", "label": "Default heading", "default": "Probiotic Feminine Products" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Shop our best-selling products, all packed with our hunger-quieting probiotic blend." },
    { "type": "text", "id": "badge_text", "label": "Card badge", "default": "Subscribe & Save 15%" },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 12,
      "label": "Products per page"
    },
    { "type": "header", "content": "Promo tile" },
    { "type": "image_picker", "id": "promo_image", "label": "Promo image" },
    {
      "type": "richtext",
      "id": "promo_text",
      "label": "Promo text",
      "default": "<p>Find the <strong>Probiotic</strong> That Fits Your Needs</p>"
    },
    {
      "type": "range",
      "id": "promo_position",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 5,
      "label": "Promo tile grid position"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Collection tab",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Tab label",
          "default": "Tab"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection grid",
      "blocks": [
        { "type": "tab", "settings": { "heading": "Best Sellers" } },
        { "type": "tab", "settings": { "heading": "Feminine Hygiene & Health" } },
        { "type": "tab", "settings": { "heading": "Gut Health" } },
        { "type": "tab", "settings": { "heading": "Anti-Oxidant & Brain Support" } },
        { "type": "tab", "settings": { "heading": "Skin Brightening" } },
        { "type": "tab", "settings": { "heading": "Shop All" } }
      ]
    }
  ]
}
{% endschema %}
