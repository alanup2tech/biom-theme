{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
{{ 'section-main-collection.css' | asset_url | stylesheet_tag }}

<section class="main-collection">
  {%- if section.settings.show_tabs -%}
    <nav class="collection-tabs" aria-label="Collections">
      {%- if section.settings.tabs_menu != blank -%}
        {%- for link in section.settings.tabs_menu.links -%}
          <a class="collection-tabs__tab{% if link.current %} is-active{% endif %}" href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        {%- assign has_collections = false -%}
        {%- for c in collections limit: 1 -%}
          {%- assign has_collections = true -%}
        {%- endfor -%}
        {%- if has_collections -%}
          {%- for c in collections limit: 5 -%}
            <a class="collection-tabs__tab{% if c.handle == collection.handle %} is-active{% endif %}" href="{{ c.url }}">{{ c.title }}</a>
          {%- endfor -%}
          <a class="collection-tabs__tab{% if collection.handle == 'all' %} is-active{% endif %}" href="{{ routes.all_products_collection_url }}">Shop All</a>
        {%- else -%}
          <a class="collection-tabs__tab" href="/collections/best-sellers">Best sellers</a>
          <a class="collection-tabs__tab" href="/collections/feminine-hygiene-health">Feminine hygiene &amp; health</a>
          <a class="collection-tabs__tab" href="/collections/gut-health">Gut health</a>
          <a class="collection-tabs__tab" href="/collections/anti-oxidant-brain-support">Anti-oxidant &amp; brain support</a>
          <a class="collection-tabs__tab" href="/collections/skin-brightening">Skin brightening</a>
          <a class="collection-tabs__tab{% if collection.handle == 'all' %} is-active{% endif %}" href="{{ routes.all_products_collection_url }}">Shop all</a>
        {%- endif -%}
      {%- endif -%}
    </nav>
  {%- endif -%}

  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="main-collection__heading reveal">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <div class="main-collection__grid">
          {%- liquid
            assign promo_pos = section.settings.promo_position
            assign idx = 0
          -%}
          {%- for product in collection.products -%}
            {%- assign idx = idx | plus: 1 -%}
            {%- if section.settings.promo_image != blank and idx == promo_pos and paginate.current_page == 1 -%}
              <div class="main-collection__promo">
                <img width="1200" height="900" src="{{ section.settings.promo_image | image_url: width: 1720 }}" alt="" loading="lazy">
                {%- if section.settings.promo_text != blank -%}
                  <div class="main-collection__promo-text">{{ section.settings.promo_text }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
            {% render 'card-product', product: product, badge: section.settings.badge_text %}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.page' | t: number: '' }}">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">&larr;</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="pagination__current" aria-current="page">{{ part.title }}</span>
              {%- else -%}
                <span>{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">&rarr;</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="main-collection__empty">
          <p class="h3">{{ 'templates.collection.empty' | t }}</p>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection grid",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "show_tabs", "label": "Show collection tabs", "default": true },
    { "type": "link_list", "id": "tabs_menu", "label": "Tabs menu" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Probiotic Feminine Products" },
    { "type": "text", "id": "badge_text", "label": "Card badge", "default": "Subscribe & Save 15%" },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 12,
      "label": "Products per page"
    },
    { "type": "header", "content": "Promo tile" },
    { "type": "image_picker", "id": "promo_image", "label": "Promo image" },
    {
      "type": "richtext",
      "id": "promo_text",
      "label": "Promo text",
      "default": "<p>Find the <strong>Probiotic</strong> That Fits Your Needs</p>"
    },
    {
      "type": "range",
      "id": "promo_position",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 5,
      "label": "Promo tile grid position"
    }
  ],
  "presets": [{ "name": "Collection grid" }]
}
{% endschema %}
