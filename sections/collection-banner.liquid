{{ 'section-collection-banner.css' | asset_url | stylesheet_tag }}

<section class="collection-banner">
  {%- if section.settings.image_left != blank -%}
    <img width="1200" height="900" class="collection-banner__img-left" src="{{ section.settings.image_left | image_url: width: 1230 }}" alt="" loading="eager">
  {%- else -%}
    <img width="600" height="450" class="collection-banner__img-left" src="{{ 'shop-banner-left.png' | asset_url }}" alt="" loading="eager">
  {%- endif -%}

  {%- if section.settings.image_right != blank -%}
    <img width="1200" height="900" class="collection-banner__img-right" src="{{ section.settings.image_right | image_url: width: 2610 }}" alt="" loading="eager" fetchpriority="high">
  {%- else -%}
    <img width="600" height="450" class="collection-banner__img-right" src="{{ 'shop-banner-right.png' | asset_url }}" alt="" loading="eager" fetchpriority="high">
  {%- endif -%}

  <div class="collection-banner__content reveal">
    <h1 class="collection-banner__heading">
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- elsif collection.title != blank and request.page_type == 'collection' -%}
        {{ collection.title }}
      {%- else -%}
        Shop All
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <br>{{ section.settings.subheading }}
      {%- endif -%}
    </h1>
    {%- if section.settings.bullets != blank -%}
      <ul class="collection-banner__bullets">
        {%- assign bullets = section.settings.bullets | newline_to_br | split: '<br />' -%}
        {%- for bullet in bullets -%}
          <li>{{ bullet | strip }}</li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection banner",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop All" },
    { "type": "text", "id": "subheading", "label": "Second line", "default": "Support for all life stages!" },
    {
      "type": "textarea",
      "id": "bullets",
      "label": "Bullet lines",
      "default": "100% Products are made in USA\nClinically studied ingredients\nVegan, non GMO, gluten free products"
    },
    { "type": "image_picker", "id": "image_left", "label": "Left image" },
    { "type": "image_picker", "id": "image_right", "label": "Right image" }
  ],
  "presets": [{ "name": "Collection banner" }]
}
{% endschema %}
