{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

<section class="image-banner">
  {%- if section.settings.image != blank -%}
    <img width="1200" height="900" class="image-banner__bg" src="{{ section.settings.image | image_url: width: 2400 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy">
  {%- else -%}
    <img width="600" height="450" class="image-banner__bg" src="{{ 'banner-yoga.png' | asset_url }}" alt="" loading="lazy">
  {%- endif -%}

  <img width="408" height="408" class="image-banner__glow" src="{{ 'banner-glow-real.png' | asset_url }}" alt="" aria-hidden="true" loading="lazy">

  {%- if section.settings.show_product_card -%}
    <div class="image-banner__card image-banner__card--product reveal">
      {%- if section.settings.product_image != blank -%}
        <img width="300" height="225" src="{{ section.settings.product_image | image_url: width: 300 }}" alt="" loading="lazy">
      {%- else -%}
        <img width="600" height="450" src="{{ 'banner-product.png' | asset_url }}" alt="" loading="lazy">
      {%- endif -%}
      <a class="btn" href="{{ section.settings.product_link | default: routes.all_products_collection_url }}">
        {{ section.settings.product_button_label }}
      </a>
    </div>
  {%- endif -%}

  {%- if section.settings.show_text_card -%}
    <div class="image-banner__card image-banner__card--text reveal">
      <div>{{ section.settings.card_text }}</div>
      <a class="image-banner__about-btn" href="{{ section.settings.about_link | default: '#' }}">
        {{ section.settings.about_label }}
      </a>
    </div>
  {%- endif -%}

  <h2 class="image-banner__title">
    {{ section.settings.title_line_1 }}<br>
    {{ section.settings.title_line_2 }}
  </h2>
</section>

{% schema %}
{
  "name": "Image banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "title_line_1", "label": "Title line 1", "default": "Support Your Body." },
    { "type": "text", "id": "title_line_2", "label": "Title line 2", "default": "Nourish Your Microbiome." },
    { "type": "header", "content": "Product card" },
    { "type": "checkbox", "id": "show_product_card", "label": "Show product card", "default": true },
    { "type": "image_picker", "id": "product_image", "label": "Product image" },
    { "type": "text", "id": "product_button_label", "label": "Button label", "default": "Shop Lean Biom" },
    { "type": "url", "id": "product_link", "label": "Button link" },
    { "type": "header", "content": "Text card" },
    { "type": "checkbox", "id": "show_text_card", "label": "Show text card", "default": true },
    {
      "type": "richtext",
      "id": "card_text",
      "label": "Text",
      "default": "<p>LeanBiom's proprietary formula is the first to combine nine clinically studied 'lean bacteria' strains with Diversify® a soluble + insoluble lean fiber enhanced with patented LiveBiom Patented technology for improved absorption.</p><p>This powerful ingredient blend works to rebalance the bacterial composition in your gut microbiome, addressing the newly uncovered root cause of belly fat and unexplained weight gain.</p>"
    },
    { "type": "text", "id": "about_label", "label": "Button label", "default": "About LeanBiom" },
    { "type": "url", "id": "about_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Image banner" }]
}
{% endschema %}
