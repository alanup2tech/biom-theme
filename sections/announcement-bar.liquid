<div class="announcement-bar" role="region" aria-label="Announcement">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" class="announcement-bar__text">{{ section.settings.text }}</a>
  {%- else -%}
    <span class="announcement-bar__text">{{ section.settings.text }}</span>
  {%- endif -%}
  {%- if section.settings.code_text != blank -%}
    <span class="announcement-bar__divider" aria-hidden="true"></span>
    <span class="announcement-bar__code">{{ section.settings.code_text }}</span>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free Shipping On Orders $25+"
    },
    {
      "type": "text",
      "id": "code_text",
      "label": "Highlighted text",
      "default": "USE CODE: SPRING20"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
