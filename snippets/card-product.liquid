{%- comment -%}
  Product card (Figma Component 126).
  Accepts either:
    product:       product object
  or static fallbacks:
    title:         string
    image_asset:   asset filename
    price:         string
    url:           string
  Optional:
    badge:         string (e.g. "Subscribe & Save 15%")
{%- endcomment -%}
{%- if product != blank -%}
  <a class="product-card" href="{{ product.url }}">
    {%- if badge != blank -%}
      <span class="product-card__badge">{{ badge }}</span>
    {%- endif -%}
    <h3 class="product-card__title">{{ product.title }}</h3>
    <span class="product-card__media">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 610 }}"
          srcset="{{ product.featured_image | image_url: width: 305 }} 305w, {{ product.featured_image | image_url: width: 610 }} 610w"
          sizes="(min-width: 750px) 305px, 70vw"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          loading="lazy"
          width="305"
          height="374"
        >
      {%- endif -%}
    </span>
    <span class="product-card__cta">
      <span class="product-card__cta-label">Shop Now</span>
      <span class="product-card__cta-price">{{ product.price | money }}</span>
    </span>
  </a>
{%- else -%}
  <a class="product-card" href="{{ url | default: '#' }}">
    {%- if badge != blank -%}
      <span class="product-card__badge">{{ badge }}</span>
    {%- endif -%}
    <h3 class="product-card__title">{{ title }}</h3>
    <span class="product-card__media">
      {%- if image_asset != blank -%}
        <img src="{{ image_asset | asset_url }}" alt="{{ title | escape }}" loading="lazy" width="305" height="374">
      {%- endif -%}
    </span>
    <span class="product-card__cta">
      <span class="product-card__cta-label">Shop Now</span>
      {%- if price != blank -%}
        <span class="product-card__cta-price">{{ price }}</span>
      {%- endif -%}
    </span>
  </a>
{%- endif -%}
